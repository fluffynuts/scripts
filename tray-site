#!/usr/bin/env python3
import re
import argparse
import sys
import subprocess
import os

from PyQt6.QtCore import QUrl
from PyQt6.QtGui import QIcon, QAction
from PyQt6.QtWidgets import QApplication, QSystemTrayIcon, QMenu, QMainWindow
self_hosted = True
try:
  from PyQt6.QtWebEngineWidgets import QWebEngineView
  from PyQt6.QtGui import QKeySequence, QShortcut

  class BrowserWindow(QMainWindow):
    def __init__(self, url: str, icon: QIcon) -> None:
      super().__init__()
      self.setWindowTitle(url)
      self.setWindowIcon(icon)
      self.resize(1024, 768)

      self._web_view = QWebEngineView()
      self._web_view.setUrl(QUrl(url))
      self.setCentralWidget(self._web_view)

      reload_action = QShortcut(QKeySequence.StandardKey.Refresh, self)
      reload_action.activated.connect(self._web_view.reload)

      back_action = QShortcut(QKeySequence.StandardKey.Back, self)
      back_action.activated.connect(self._web_view.back)

      forward_action = QShortcut(QKeySequence.StandardKey.Forward, self)
      forward_action.activated.connect(self._web_view.forward)

    def closeEvent(self, event: "QCloseEvent") -> None:
      # Hide instead of destroying so we can re-show later
      event.ignore()
      self.hide()

except:
  self_hosted = False
  class BrowserWindow:
    def __init__(self, url: str, icon: QIcon) -> None:
      self.url = url
      pass

    def closeEvent(self, event: "QCloseEvent") -> None:
      pass

def open_url(url: str) -> None:
  subprocess.Popen(["xdg-open", url])

def toggle_window(window: BrowserWindow) -> None:
  if self_hosted:
    if window.isVisible() and window.isActiveWindow():
      window.hide()
    else:
      window.show()
      window.raise_()
      window.activateWindow()
  else:
    open_url(window.url)


def parse_args() -> argparse.Namespace:
  parser = argparse.ArgumentParser(description="System tray launcher for a URL")
  parser.add_argument("-i", "--icon", required=True, help="System theme icon name or path to icon file")
  parser.add_argument("-u", "--url", required=True, help="URL to open on click")
  return parser.parse_args()


def main() -> None:
  args = parse_args()

  if get_running_pid(args.url, args.icon) is not None:
    print("already running")
    return

  app = QApplication(sys.argv)
  app.setQuitOnLastWindowClosed(False)

  if os.path.isfile(args.icon):
    print(f"load icon from {args.icon}")
    icon = QIcon(args.icon)
  else:
    icon = QIcon.fromTheme(args.icon)

  window = BrowserWindow(args.url, icon)

  tray = QSystemTrayIcon(icon, app)

  tray.activated.connect(
    lambda reason: toggle_window(window)
    if reason == QSystemTrayIcon.ActivationReason.Trigger
    else None
  )

  menu = QMenu()
  exit_action = QAction("Exit")
  exit_action.triggered.connect(app.quit)
  menu.addAction(exit_action)
  tray.setContextMenu(menu)

  tray.show()
  sys.exit(app.exec())


def lock_file_path(url: str, icon: str) -> str:
  safe_url = re.sub(r"[/:]+", "-", url).strip("-")
  safe_url = re.sub(r"[?&=]", "_", safe_url)
  if os.path.exists(icon):
    icon = os.path.basename(icon)
  return f"/tmp/tray-site-{icon}-{safe_url}.pid"


def get_running_pid(url: str, icon: str) -> int | None:
  """
  Check if another instance is running.
  Returns the PID of the running instance, or None if not running.
  Writes our own PID file if no other instance is found.
  """
  pidfile = lock_file_path(url, icon)
  if not os.path.exists(pidfile):
    write_pid_file(pidfile)
    return None
  with open(pidfile, "r") as fp:
    existing_pid = int(fp.read().strip())
    try:
      os.kill(existing_pid, 0)
      return existing_pid
    except ProcessLookupError:
      write_pid_file(pidfile)
      return None


def write_pid_file(pidfile: str) -> None:
  with open(pidfile, "w") as fp:
    pid = str(os.getpid())
    fp.write(pid)


if __name__ == "__main__":
  main()
