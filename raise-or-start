#!/bin/env python3
import subprocess
import sys
from pathlib import Path
import os
import shutil

EXIT_CODE_BAD_ARGS=1
EXIT_CODE_BAD_ENV=2
EXIT_CODE_MISSING_TOOL=3

def find_window(search: str) -> str | None:
  try:
    result = subprocess.run(
      ["kdotool", "search", "--name", search],
      capture_output=True, text=True, timeout=2
    )
    window_ids = result.stdout.strip().splitlines()
    if window_ids:
      print(f"found window(s): {window_ids}")
      return window_ids[0]
    print(f"no window found for search term '{search}'")
    return None
  except (subprocess.TimeoutExpired, FileNotFoundError) as e:
    print(f"nestray: kdotool search failed: {e}", file=sys.stderr)
    return None


def raise_or_start(window_search: str, fallback_command: str) -> None:
  """Find the Thunderbird window ID via kdotool, or None if not found."""
  try:
    wid = find_window(window_search)
    if wid is None:
      print(f"starting fallback command: {fallback_command}")
      run_fallback(fallback_command)
    else:
      print(f"activating window {wid}")
      subprocess.run([
        "kdotool",
        "windowactivate",
        wid
      ])
  except (subprocess.TimeoutExpired, FileNotFoundError) as e:
    print(f"kdotool search failed: {e}", file=sys.stderr)
    run_fallback(fallback_command)
    return None


def run_fallback(cmd: str) -> None:
  print(f"starting fallback command: {cmd}")
  try:
    subprocess.Popen(
      cmd,
      stdout=subprocess.DEVNULL,
      stderr=subprocess.DEVNULL,
      start_new_session=True,
      shell=True
    )
  except FileNotFoundError:
    print(f"cannot launch command: not found: {cmd}")

def verify_environment():
  desktop_environment = os.environ.get("XDG_CURRENT_DESKTOP")
  session_type = os.environ.get("XDG_SESSION_TYPE")
  forced = os.environ.get("FORCE")
  if desktop_environment != "KDE" or session_type != "wayland":
    print(
      f"""
      WARNING: this utility is designed to work on KDE in a wayland session.
      Your environment reports:
      XDG_CURRENT_DESKTOP: {desktop_environment}
      XDG_SESSION_TYPE: {session_type}
      """
    )
    if forced != "1":
      print("you may suppress this warning and try anyway if you set the environment variable FORCE=1")
      sys.exit(EXIT_CODE_BAD_ENV)
    if not shutil.which("kdotool"):
      print("this utility requires kdotool to be in your path")
      sys.exit(EXIT_CODE_BAD_ENV);


def usage() -> None:
  me = Path(sys.argv[0]).name
  print(f"Usage: {me} <search string> <optional fallback command, defaults to search string>")
  print(f"  eg: {me} Thunderbird thunderbird")
  print(f"  or: {me} Thunderbird /usr/bin/thunderbird")
  print(f"  or: {me} SomeWindowClass \"/path/to/app --option foo\"")
  print(f"exit codes:")
  print(f"  0 - ok!")
  print(f"  {EXIT_CODE_BAD_ARGS} - missing arguments (you should see help)")
  print(f"  {EXIT_CODE_BAD_ENV} - invalid environment (DE, display server)")
  print(f"  {EXIT_CODE_MISSING_TOOL} - missing required system tooling")


def main() -> None:
  verify_environment()
  args = sys.argv[1:]
  if len(args) == 0:
    usage()
    sys.exit(EXIT_CODE_BAD_ARGS)
  if len(args) == 1:
    args.append(args[0])

  raise_or_start(
    args[0],
    args[1]
  )


if __name__ == "__main__":
  main()
